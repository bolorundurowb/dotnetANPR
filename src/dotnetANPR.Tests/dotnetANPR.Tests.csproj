<Project Sdk="MSTest.Sdk/4.2.3">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="OmniAssert" Version="2.0.0" />
        <PackageReference Update="Microsoft.Testing.Extensions.CodeCoverage" Version="18.8.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\dotnetANPR\dotnetANPR.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\dotnetANPR\Resources\syntax.xml">
            <Link>Resources\syntax.xml</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

</Project>
